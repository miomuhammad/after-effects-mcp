{
  "name": "after-effects-mcp",
  "version": "1.0.0",
  "description": "MCP server for Adobe After Effects",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=build/index.js --packages=external && copyfiles -u 1 \"src/scripts/**/*\" build",
    "typecheck": "tsc --noEmit",
    "start": "node build/index.js",
    "install-bridge": "node install-bridge.js",
    "evaluate-prompts": "node tools/evaluate-prompt-suite.mjs",
    "smoke:bridge": "node tools/bridge-reliability-smoke.mjs",
    "smoke:v6": "node tools/v6-transaction-smoke.mjs",
    "bridge:send": "node tools/send-bridge-command.mjs",
    "bridge:wait": "node tools/wait-bridge-result.mjs",
    "wrapper:maker": "node tools/wrapper-maker/index.mjs",
    "release-readiness": "node tools/release-readiness.mjs",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.2.2"
  }
}
